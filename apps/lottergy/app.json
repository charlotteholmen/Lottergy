{
  "expo": {
    "name": "Lottergy",
    "slug": "lottergy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lottergy",
    "userInterfaceStyle": "automatic",
    "description": "What's Your Lottergy to Win? Browse lottery historical data, run your own filters and Monte Carlo simulations, and save named strategies.",
    "primaryColor": "#208AEF",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.thebitmaptoshi.lottergy",
      "supportsTablet": true
    },
    "android": {
      "package": "com.thebitmaptoshi.lottergy",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Lottergy",
      "shortName": "Lottergy",
      "themeColor": "#208AEF",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "any"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
